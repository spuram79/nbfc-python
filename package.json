{
  "name": "nbfc-multiapp-monorepo",
  "version": "1.0.0",
  "description": "NBFC SaaS Platform - Multi-Application Monorepo",
  "private": true,
  "scripts": {
    "dev:all": "concurrently \"npm run dev:services\" \"npm run dev:apps\"",
    "dev:services": "echo \"Starting microservices...\"",
    "dev:apps": "concurrently \"npm run dev:admin\" \"npm run dev:branch\" \"npm run dev:customer\" \"npm run dev:field-agent\" \"npm run dev:collections\"",
    "dev:admin": "cd apps/admin && npm run dev",
    "dev:branch": "cd apps/branch && npm run dev",
    "dev:customer": "cd apps/customer && npm run dev",
    "dev:field-agent": "cd apps/field-agent && npm run dev",
    "dev:collections": "cd apps/collections && npm run dev",
    "build:all": "npm run build:apps && npm run build:services",
    "build:apps": "concurrently \"cd apps/admin && npm run build\" \"cd apps/branch && npm run build\" \"cd apps/customer && npm run build\" \"cd apps/field-agent && npm run build\" \"cd apps/collections && npm run build\"",
    "build:services": "echo \"Building services...\"",
    "test": "lerna run test",
    "lint": "lerna run lint",
    "docker:build": "docker-compose -f infrastructure/docker-compose.yml build",
    "docker:up": "docker-compose -f infrastructure/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker-compose.yml down",
    "k8s:deploy": "kubectl apply -f infrastructure/k8s/",
    "k8s:delete": "kubectl delete -f infrastructure/k8s/"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^8.2.0",
    "lerna": "^8.1.0"
  }
}
